# -----------------------------------------------------------------------------
# AI Hedge Fund Configuration
# -----------------------------------------------------------------------------
# Copy this file to .env and modify the values as needed

# -----------------------------------------------------------------------------
# Data Configuration
# -----------------------------------------------------------------------------

# Choose your market data source:
# - yahoo (free, via yfinance)
# - financialdatasets (requires FINANCIAL_DATASETS_API_KEY)
DATA_PROVIDER=yahoo

# Enable/disable data caching
DATA_CACHE_ENABLED=true

# Cache time-to-live in seconds (default: 1 hour)
DATA_CACHE_TTL=3600

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------

# Ollama base URL for local models
OLLAMA_BASE_URL=http://localhost:11434

# Default Ollama model to use
DEFAULT_OLLAMA_MODEL=qwen3.5:latest

# LLM request timeout in seconds
LLM_TIMEOUT=30

# Maximum retries for LLM requests
LLM_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# API Keys (Optional - only set what you use)
# -----------------------------------------------------------------------------

# Financial Datasets API key (required if DATA_PROVIDER=financialdatasets)
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# OpenAI API key
OPENAI_API_KEY=your-openai-api-key

# Anthropic API key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Groq API key
GROQ_API_KEY=your-groq-api-key

# DeepSeek API key
DEEPSEEK_API_KEY=your-deepseek-api-key

# -----------------------------------------------------------------------------
# Performance Configuration
# -----------------------------------------------------------------------------

# Maximum concurrent API requests
MAX_CONCURRENT_REQUESTS=5

# Request timeout in seconds
REQUEST_TIMEOUT=30

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/ai_hedge_fund.log

# Maximum log file size in MB
LOG_MAX_SIZE_MB=10

# Number of backup log files to keep
LOG_BACKUP_COUNT=5

# -----------------------------------------------------------------------------
# Backtesting Configuration
# -----------------------------------------------------------------------------

# Default initial capital for backtesting
DEFAULT_INITIAL_CAPITAL=100000.0

# Default margin requirement ratio
DEFAULT_MARGIN_REQUIREMENT=0.0

# -----------------------------------------------------------------------------
# Redis Configuration (Optional - for enhanced caching)
# -----------------------------------------------------------------------------

# Redis host
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis password (if required)
REDIS_PASSWORD=your-redis-password

# Redis database number
REDIS_DB=0

# -----------------------------------------------------------------------------
# Notes:
# -----------------------------------------------------------------------------
# 1. For completely free operation:
#    - Set DATA_PROVIDER=yahoo
#    - Use local Ollama models (no cloud API keys needed)
#    - Comment out or remove all API key settings
#
# 2. For paid features:
#    - Set DATA_PROVIDER=financialdatasets and provide FINANCIAL_DATASETS_API_KEY
#    - Provide appropriate LLM API keys for cloud models
#
# 3. Redis is optional but recommended for production use